FROM node:22-bookworm-slim
WORKDIR /app
ENV HUSKY=0

# 1. Install build tools (Essential for sqlite3 C++ bindings)
RUN apt-get update && apt-get install -y python3 build-essential

RUN corepack enable

# 2. Copy everything
COPY . .

# 3. Install and EXPLICITLY rebuild sqlite3
RUN pnpm install --no-frozen-lockfile
RUN pnpm rebuild sqlite3

# 4. Build the Nx project
RUN pnpm build

# 5. Runtime setup
WORKDIR /app/ghost/core
EXPOSE 2368
CMD [ "node", "index.js" ]
